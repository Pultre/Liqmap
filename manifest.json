{
  "manifest_version": 3,
  "name": "LiqMap — Coinglass Liquidation Heatmap",
  "version": "1.0.0",
  "description": "Instantly open the Coinglass liquidation heatmap for any token you're watching on TradingView",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://www.tradingview.com/*",
    "https://www.coinglass.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.tradingview.com/*"],
      "js": ["content.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
